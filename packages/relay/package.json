{
  "name": "@wdk-app/relay",
  "version": "0.1.0",
  "description": "WDK-APP Relay Server - message relay between daemon and RN app",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "dev": "node --loader ts-node/esm --watch src/index.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "test": "node --experimental-vm-modules ../../node_modules/.bin/jest"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "@fastify/websocket": "^11.0.2",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "jsonwebtoken": "^9.0.2",
    "expo-server-sdk": "^3.13.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "ts-node": "^10.9.0",
    "ts-jest": "^29.1.0",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@types/pg": "^8.11.0",
    "@types/jsonwebtoken": "^9.0.5",
    "pino-pretty": "^13.0.0",
    "jest": "^29.7.0",
    "@jest/globals": "^29.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
